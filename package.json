{
  "name": "portfolio-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "vite build && npm run build:vite --prefix novella && npm run build:api",
    "build:api": "esbuild scripts/api-handler.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=api/index.js --external:better-sqlite3",
    "build:portfolio": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@google/generative-ai": "^0.24.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "emailjs": "^4.0.3",
    "express": "^4.21.2",
    "framer-motion": "^10.x",
    "lucide-react": "^0.263.1",
    "motion": "^12.0.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.1.2",
    "serverless-http": "^3.2.0",
    "three": "^0.174.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.x",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
